# Database (Docker Compose 서비스명 'db' 사용 예시)
DATABASE_URL=postgresql://user:password@db:5432/cukee_db

# Security
SECRET_KEY=실제-운영용-비밀키-입력
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS (프론트엔드 도메인 추가)
ALLOWED_ORIGINS=http://localhost:3000,https://cloudkakao.store

# Environment
ENVIRONMENT=production